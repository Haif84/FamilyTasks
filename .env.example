BOT_TOKEN=replace_me

# Локально: путь относительно cwd. В Docker (docker-compose) путь к БД задаётся в compose
# (/app/data/…); строку DB_PATH в .env на сервере можно не указывать или оставить для локального запуска.
DB_PATH=./data/family_tasks.sqlite3

LOG_LEVEL=INFO

# === Alice webhook (MVP "добавить выполненную") ===
# Включить встроенный HTTP endpoint для навыка Алисы.
ALICE_WEBHOOK_ENABLED=false

# Где слушать webhook внутри процесса бота.
ALICE_WEBHOOK_HOST=0.0.0.0
ALICE_WEBHOOK_PORT=8080
ALICE_WEBHOOK_PATH=/alice/webhook
